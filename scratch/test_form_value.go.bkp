package main

import (
	"fmt"
	"net/http"
	"net/http/httptest"
	"net/url"
	"strings"
)

func main() {
	handler := func(w http.ResponseWriter, r *http.Request) {
		if err := r.ParseForm(); err != nil {
			http.Error(w, err.Error(), http.StatusBadRequest)
			return
		}
		fmt.Printf("FormValue('mock'): %s\n", r.FormValue("mock"))
		fmt.Printf("Form['mock']: %v\n", r.Form["mock"])
	}

	// Test Case 1: POS body has mock
	body := url.Values{}
	body.Set("prompt", "test")
	body.Set("mock", "body_true")
	req1 := httptest.NewRequest("POST", "/test?mock=query_true", strings.NewReader(body.Encode()))
	req1.Header.Set("Content-Type", "application/x-www-form-urlencoded")
	
	fmt.Println("Case 1: Both query and body have 'mock'")
	w1 := httptest.NewRecorder()
	handler(w1, req1)

	// Test Case 2: Only query has mock
	body2 := url.Values{}
	body2.Set("prompt", "test")
	req2 := httptest.NewRequest("POST", "/test?mock=query_true", strings.NewReader(body2.Encode()))
	req2.Header.Set("Content-Type", "application/x-www-form-urlencoded")
	
	fmt.Println("\nCase 2: Only query has 'mock'")
	w2 := httptest.NewRecorder()
	handler(w2, req2)
}
